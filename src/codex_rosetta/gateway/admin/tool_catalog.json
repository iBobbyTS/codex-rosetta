  "builtin_profile": {
    "id": "builtin",
    "name": "Chat Default",
    "tools": {
      "namespace.multi_agent_v1": "disabled"
    },
    "inputs": {
      "function.request_user_input": {
        "guidance": "Use this only for real user preferences or decisions that materially change the plan. Do not use it to ask whether to approve, proceed with, or implement a proposed plan; after emitting the final <proposed_plan> block, let the Codex UI handle approval and implementation. Keep option labels short natural phrases without A:/B:/C: prefixes."
      },
      "function.create_goal": {
        "guidance": "Call this when the user explicitly asks to mark a goal complete or blocked but get_goal returns no active goal, or update_goal reports that the thread has no goal. Do not set token_budget unless the user explicitly provided a numeric token budget."
      },
      "function.update_goal": {
        "guidance": "Before updating a goal, use get_goal when goal state is uncertain. If no active goal exists or this tool reports that the thread has no goal, call create_goal first with a concise objective and no token_budget unless explicitly requested, then retry update_goal with the requested status."
      },
      "custom.exec": {
        "guidance": "Pass raw JavaScript source in the input string. Do not serialize an exec call object or include input, yield_time_ms, or max_output_tokens as JavaScript object properties. Configure yielding only with the // @exec pragma. For nested tools, await tools.<name>(...) and call text(...) or image(...) with the result when the user or task needs to inspect it. A Script completed result is final; call wait only when exec explicitly returns Script running with cell ID."
      },
      "namespace.multi_agent_v2.list_agents": {
        "guidance": "path_prefix filters canonical task paths. Use the requested child task-name segment, and treat the returned status and result for that canonical path as authoritative."
      },
      "namespace.multi_agent_v2.send_message": {
        "guidance": "target must be the canonical task path returned by spawn_agent. Send the requested message exactly; this delivers to the existing child and does not start a replacement task."
      },
      "namespace.multi_agent_v2.spawn_agent": {
        "guidance": "The message field is the complete child task. With fork_turns=\"none\", the child receives no surrounding user turns, so include every instruction the child must follow in message and do not expect it to reconstruct the task from workspace files."
      },
      "namespace.multi_agent_v2.wait_agent": {
        "guidance": "This waits for a future mailbox update; it does not replay a completion notification already delivered in the current input. If that completion is already visible, treat it as authoritative instead of repeatedly waiting by reflex."
      },
      "namespace.mcp_github": {
        "owner_guidance": "Do not guess. If the owner is not explicitly provided, inspect the local git remote first, for example by running git remote -v.",
        "repo_guidance": "Do not guess. If the repository name is not explicitly provided, derive it from the user request or inspect the local git remote first, for example by running git remote -v."
      }
    }
  },
