{
  // Provider credentials and base URLs.
  // API keys support ${ENV_VAR} syntax for environment variable substitution.
  "providers": {
    "openai_chat": {
      "api_key": "${OPENAI_API_KEY}",
      "base_url": "https://api.openai.com/v1"
    },
    "openai_responses": {
      "api_key": "${OPENAI_API_KEY}",
      "base_url": "https://api.openai.com/v1"
    },
    "anthropic": {
      "api_key": "${ANTHROPIC_API_KEY}",
      "base_url": "https://api.anthropic.com"
    },
    "google": {
      "api_key": "${GOOGLE_API_KEY}",
      "base_url": "https://generativelanguage.googleapis.com"
    }
  },

  // Model → provider routing table.
  // When a request arrives with a given model name, the gateway
  // looks up the target provider here.
  "models": {
    "gpt-4o": "openai_chat",
    "gpt-4o-mini": "openai_chat",
    "gpt-4.1": "openai_chat",
    "gpt-4.1-mini": "openai_chat",
    "gpt-4.1-nano": "openai_chat",
    "claude-sonnet-4-20250514": "anthropic",
    "claude-3-5-haiku-20241022": "anthropic",
    "gemini-2.0-flash": "google",
    "gemini-2.5-pro": "google",
    "gemini-2.5-flash": "google"
  },

  // Server settings
  "server": {
    // Keep loopback for local use. Docker overrides this to 0.0.0.0 and must
    // retain the mandatory password and access key below.
    "host": "127.0.0.1",
    "port": 8765,
    "admin_password": "${CODEX_ROSETTA_ADMIN_PASSWORD}",
    "credential_visible": false,
    "api_keys": [
      {
        "id": "default",
        "label": "Default client",
        "key": "${CODEX_ROSETTA_API_KEY}"
      }
    ]
  }
}
